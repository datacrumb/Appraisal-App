// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Form {
  id          String      @id @default(uuid())
  title       String
  description String?
  questions   Json        // Array of questions (customizable)
  createdAt   DateTime    @default(now())
  createdBy   String      // Admin User ID (Clerk)
  assignments Assignment[]
}

model Assignment {
  id            String      @id @default(uuid())
  form          Form        @relation(fields: [formId], references: [id])
  formId        String
  employeeId    String      // Clerk User ID
  employeeEmail String      // Store email at assignment time
  responses     Response[]
  summary       Summary?
  assignedAt    DateTime    @default(now())
}

model Response {
  id           String      @id @default(uuid())
  assignment   Assignment  @relation(fields: [assignmentId], references: [id])
  assignmentId String
  responderId  String      // Clerk User ID (self or peer)
  answers      Json        // Answers to the form questions
  createdAt    DateTime    @default(now())
  isPeer       Boolean     // True if this is a peer feedback, false if self
}

model Summary {
  id           String      @id @default(uuid())
  assignment   Assignment  @relation(fields: [assignmentId], references: [id])
  assignmentId String      @unique
  content      String      // AI-generated summary
  approved     Boolean     // Admin approval
  createdAt    DateTime    @default(now())
  approvedAt   DateTime?
}

// Updated Employee model with comprehensive fields
model Employee {
  id           String   @id           // Clerk User ID
  email        String   @unique
  firstName    String?
  lastName     String?
  department   String?
  role         String?
  isManager    Boolean  @default(false)
  isLead       Boolean  @default(false)
  createdAt    DateTime @default(now())
  
  // Relations
  relationsFrom EmployeeRelation[] @relation("FromEmployee")
  relationsTo   EmployeeRelation[] @relation("ToEmployee")
}

model EmployeeRelation {
  id           String   @id @default(uuid())
  fromId       String
  toId         String
  type         RelationType

  from         Employee @relation("FromEmployee", fields: [fromId], references: [id])
  to           Employee @relation("ToEmployee", fields: [toId], references: [id])

  @@unique([fromId, toId, type])
}

enum RelationType {
  MANAGER
  LEAD
  COLLEAGUE
}

// New model for onboarding requests (replaces Google Sheets)
model OnboardingRequest {
  id           String   @id @default(uuid())
  userId       String   @unique // Clerk User ID
  email        String
  firstName    String
  lastName     String
  department   String
  role         String
  isManager    Boolean  @default(false)
  isLead       Boolean  @default(false)
  managerEmail String?  // Email of their manager
  status       OnboardingStatus @default(PENDING)
  createdAt    DateTime @default(now())
  approvedAt   DateTime?
  approvedBy   String?  // Admin who approved
}

enum OnboardingStatus {
  PENDING
  APPROVED
  REJECTED
}
