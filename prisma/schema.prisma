// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid()) // Use Clerk user ID
  email     String   @unique
  name      String?
  role      Role     @default(EMPLOYEE)
  responses Response[]
  assignments Assignment[]
}

enum Role {
  ADMIN
  EMPLOYEE
}

model Form {
  id          String      @id @default(uuid())
  title       String
  description String?
  questions   Json        // Array of questions (customizable)
  createdAt   DateTime    @default(now())
  createdBy   String      // Admin User ID
  assignments Assignment[]
}

model Assignment {
  id         String      @id @default(uuid())
  form       Form        @relation(fields: [formId], references: [id])
  formId     String
  employee   User        @relation(fields: [employeeId], references: [id])
  employeeId String
  responses  Response[]
  summary    Summary?
  assignedAt DateTime    @default(now())
}

model Response {
  id           String      @id @default(uuid())
  assignment   Assignment  @relation(fields: [assignmentId], references: [id])
  assignmentId String
  responder    User        @relation(fields: [responderId], references: [id])
  responderId  String      // The user who submitted this response (self or peer)
  answers      Json        // Answers to the form questions
  createdAt    DateTime    @default(now())
  isPeer       Boolean     // True if this is a peer feedback, false if self
}

model Summary {
  id           String      @id @default(uuid())
  assignment   Assignment  @relation(fields: [assignmentId], references: [id])
  assignmentId String      @unique
  content      String      // AI-generated summary
  approved     Boolean     // Admin approval
  createdAt    DateTime    @default(now())
  approvedAt   DateTime?
}
